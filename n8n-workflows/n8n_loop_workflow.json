        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $json.summary }}\",\n  \"from\": \"{{ $json.from_number }}\"\n}"
      },
      "id": "node-herald-medium",
      "name": "HERALD — WhatsApp Advice",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1300, 560]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8001/webhook/whatsapp",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $json.summary }}\",\n  \"from\": \"{{ $json.from_number }}\"\n}"
      },
      "id": "node-herald-low",
      "name": "HERALD — Low Priority Info",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1300, 740]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/calls",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"call_id\":     \"{{ $json.call_id }}\",\n  \"from_number\": \"{{ $json.from_number }}\",\n  \"intent\":      \"{{ $json.intent }}\",\n  \"urgency\":     \"{{ $json.urgency }}\",\n  \"transcript\":  \"{{ $json.summary }}\",\n  \"ai_summary\":  \"{{ $json.reasoning }}\",\n  \"outcome\":     \"{{ $json.urgency === 'EMERGENCY' || $json.urgency === 'HIGH' ? 'escalated' : 'resolved' }}\",\n  \"agent_used\":  \"NEXUS-LOOP-v3\"\n}"
      },
      "id": "node-supabase-log",
      "name": "LEDGER — Log to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.MAKE_WEBHOOK_URL }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"call_id\":   \"{{ $json.call_id }}\",\n  \"urgency\":   \"{{ $json.urgency }}\",\n  \"summary\":   \"{{ $json.summary }}\",\n  \"source\":    \"{{ $json.source }}\",\n  \"location\":  \"{{ $json.location }}\",\n  \"timestamp\": \"{{ $json.timestamp }}\"\n}"
      },
      "id": "node-make",
      "name": "Make.com — Alert + Google Sheets",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 700]
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    status: 'processed',\n    call_id: $('Parse Intent + Merge').first().json.call_id,\n    urgency: $('Parse Intent + Merge').first().json.urgency,\n    loop_iteration: $('Parse Intent + Merge').first().json.loop_iteration,\n    message: 'NEXUS loop iteration complete',\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "node-respond",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1800, 500]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}"
      },
      "id": "node-webhook-respond",
      "name": "Return 200 OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [2000, 500]
    },
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 6 }]
        }
      },
      "id": "node-loop-schedule",
      "name": "⏰ Loop Trigger — Every 6 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [100, 900]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://qrng.anu.edu.au/API/jsonI.php?length=8&type=hex16",
        "options": { "timeout": 8000 }
      },
      "id": "node-qrng",
      "name": "HELIX — Fetch Quantum Seed (ANU QRNG)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [340, 900]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key",          "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version",  "value": "2023-06-01" },
            { "name": "Content-Type",       "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 400,\n  \"system\": \"You are BASIRA, the NEXUS community health prediction agent for Al Qua'a, UAE. Analyze patterns and output ONLY valid JSON: {\\\"week_prediction\\\": \\\"brief forecast\\\", \\\"high_risk_conditions\\\": [\\\"list\\\"], \\\"recommended_pre_positioning\\\": \\\"what clinic should prepare\\\", \\\"alert_level\\\": \\\"NORMAL|ELEVATED|HIGH\\\"}\",\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Loop iteration {{ $runIndex }}. Quantum seed: {{ $json.data ? $json.data[0] : 'offline' }}. Generate weekly health demand forecast for Al Qua'a rural community.\"\n  }]\n}"
      },
      "id": "node-basira",
      "name": "BASIRA — Community Health Prediction",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [580, 900]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key",          "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version",  "value": "2023-06-01" },
            { "name": "Content-Type",       "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 200,\n  \"system\": \"You are MOSCA, the NEXUS quantum risk agent. Output ONLY valid JSON: {\\\"risk_level\\\": \\\"LOW|MEDIUM|HIGH|CRITICAL\\\", \\\"mosca_score\\\": number, \\\"action\\\": \\\"brief action\\\"}\",\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Calculate current quantum security risk for Al Qua'a health data. Loop: {{ $runIndex }}\"\n  }]\n}"
      },
      "id": "node-mosca-loop",
      "name": "MOSCA — Daily Risk Loop",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [820, 900]
    },
