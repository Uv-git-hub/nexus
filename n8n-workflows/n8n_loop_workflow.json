{
  "name": "NEXUS — Multi-Agent Loop Engine (Challenge 2)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "nexus-emergency",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node-webhook-emergency",
      "name": "Emergency Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 400]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "nexus-basar",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node-webhook-basar",
      "name": "BASAR CV Alert Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 600]
    },
    {
      "parameters": {
        "jsCode": "// Normalize payload from HERALD, BASAR, or VAPI\nconst body = $input.first().json.body || $input.first().json;\n\nconst urgency      = body.urgency      || 'MEDIUM';\nconst summary      = body.summary      || body.triage_summary || 'Community member needs assistance';\nconst from_number  = body.from_number  || body.caller        || 'unknown';\nconst source       = body.source       || body.event_type    || 'HERALD';\nconst location     = body.location     || 'Al Qua\\'a, Al Ain, UAE';\nconst call_id      = body.call_id      || `nexus_${Date.now()}`;\n\nreturn [{\n  json: {\n    urgency,\n    summary,\n    from_number,\n    source,\n    location,\n    call_id,\n    timestamp: new Date().toISOString(),\n    loop_iteration: body.loop_iteration || 1\n  }\n}];"
      },
      "id": "node-normalize",
      "name": "Normalize Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [340, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key",          "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version",  "value": "2023-06-01" },
            { "name": "Content-Type",       "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 300,\n  \"system\": \"You are the NEXUS Triage Intent Classifier for rural UAE communities (Challenge 2: Reaching people quickly). Analyze the input and output ONLY valid JSON:\\n{\\\"intent\\\": \\\"emergency|query|escalate|false_alarm\\\", \\\"urgency\\\": \\\"LOW|MEDIUM|HIGH|EMERGENCY\\\", \\\"requires_voice_call\\\": true/false, \\\"requires_whatsapp\\\": true/false, \\\"estimated_response_minutes\\\": number, \\\"confidence\\\": 0.0-1.0, \\\"reasoning\\\": \\\"one line\\\"}\",\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Source: {{ $json.source }}\\nUrgency claimed: {{ $json.urgency }}\\nSummary: {{ $json.summary }}\\nLocation: {{ $json.location }}\"\n  }]\n}"
      },
      "id": "node-intent-classifier",
      "name": "ORACLE Intent Classifier (Claude)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [580, 500]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.content[0].text;\nlet classification;\ntry {\n  classification = JSON.parse(raw);\n} catch(e) {\n  classification = { intent: 'escalate', urgency: 'HIGH', requires_voice_call: true, requires_whatsapp: true, estimated_response_minutes: 5, confidence: 0.7, reasoning: 'Parse fallback' };\n}\n\n// Merge with previous node data\nconst prev = $('Normalize Payload').first().json;\n\nreturn [{\n  json: {\n    ...prev,\n    intent:                    classification.intent,\n    urgency:                   classification.urgency,\n    requires_voice_call:       classification.requires_voice_call,\n    requires_whatsapp:         classification.requires_whatsapp,\n    estimated_response_minutes:classification.estimated_response_minutes,\n    confidence:                classification.confidence,\n    reasoning:                 classification.reasoning\n  }\n}];"
      },
      "id": "node-parse-intent",
      "name": "Parse Intent + Merge",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [820, 500]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.urgency }}",
        "rules": {
          "rules": [
            { "value2": "EMERGENCY", "output": 0 },
            { "value2": "HIGH",      "output": 1 },
            { "value2": "MEDIUM",    "output": 2 },
            { "value2": "LOW",       "output": 3 }
          ]
        },
        "fallbackOutput": 2
      },
      "id": "node-urgency-router",
      "name": "Urgency Router (Switch)",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1060, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8002/trigger-call",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"urgency\": \"{{ $json.urgency }}\",\n  \"summary\": \"{{ $json.summary }}\",\n  \"location\": \"{{ $json.location }}\",\n  \"source\": \"{{ $json.source }}\",\n  \"clinic_phone\": \"{{ $env.DEMO_CLINIC_PHONE }}\"\n}"
      },
      "id": "node-sawt-emergency",
      "name": "SAWT — Emergency Voice Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1300, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8002/trigger-call",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"urgency\": \"{{ $json.urgency }}\",\n  \"summary\": \"{{ $json.summary }}\",\n  \"location\": \"{{ $json.location }}\",\n  \"source\": \"{{ $json.source }}\",\n  \"clinic_phone\": \"{{ $env.DEMO_CLINIC_PHONE }}\"\n}"
      },
      "id": "node-sawt-high",
      "name": "SAWT — High Priority Voice Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1300, 380]
    },
